{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "quill",
  "name": "Barekey",
  "colors": {
    "primary": "#334155",
    "light": "#475569",
    "dark": "#1E2939"
  },
  "fonts": {
    "heading": { "family": "Google Sans" },
    "body": { "family": "Google Sans" }
  },
  "background": {
    "color": {
      "light": "#F8FAFB",
      "dark": "#0F1520"
    }
  },
  "favicon": "/images/barekey-light.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/how-barekey-works",
              "concepts/variable-kinds",
              "concepts/security-model"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/javascript-sdk",
              "integrations/cli"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "roadmap/documentation-plan"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Environment API",
            "pages": [
              "api-reference/evaluate",
              "api-reference/manage-environment"
            ]
          },
          {
            "group": "CLI and tooling",
            "pages": [
              "api-reference/cli-auth",
              "api-reference/typegen-manifest"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://barekey.dev",
          "icon": "app-window"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/usebarekey/barekey",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/barekey-dark.png",
    "dark": "/images/barekey-light.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://github.com/usebarekey/barekey/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://barekey.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/usebarekey/barekey"
    }
  },
  "description": "Barekey documentation for encrypted variables, .env replacement workflows, the CLI, the JavaScript SDK, and optional dynamic kinds.",
  "seo": {
    "metatags": {
      "canonical": "https://docs.barekey.dev"
    }
  }
}
